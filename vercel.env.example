MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ebatlama?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# İlk admin hesabı için
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Sistem Yöneticisi

# Frontend aynı Vercel projesinde çalıştığı için varsayılan değer /api olabilir.
# Ayrı domain kullanacaksanız tam API adresini yazın.
REACT_APP_API_URL=/api