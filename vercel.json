{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": "build"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "installCommand": "npm install"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
